# Required
DATABASE_URL=postgresql://user:pass@host:5432/magpie

# Embeddings (optional — keyword search works without it)
OPENAI_API_KEY=sk-...

# Auth (optional — empty = no auth, good for local dev)
API_KEY=
SESSION_SECRET=

# Email OTP (optional — API key login always works)
RESEND_API_KEY=
RESEND_FROM=magpie <noreply@erdo.ai>
